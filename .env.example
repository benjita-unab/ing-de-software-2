# Variables para Docker Compose (raíz).
# Copia este archivo a `.env` en la raíz del repositorio.
# También crea `backend/.env` y `frontend/.env` a partir de sus respectivos `.env.example`.

# Puertos expuestos en el host
BACKEND_PORT=3000
FRONTEND_PORT=3001
NGINX_PORT=8080

# CORS del backend (origen del portal web en Docker)
FRONTEND_URL=http://localhost:3001

# --- Backend (obligatorias para Supabase) ---
JWT_SECRET=super_secret_key_123456
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# --- Backend (opcionales) ---
RESEND_API_KEY=re_tu_clave_resend
RESEND_FROM_EMAIL=Sistema LogiTrack <onboarding@resend.dev>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASS=tu_app_password_sin_espacios
SMTP_FROM_NAME=LogiTrack Web
GOOGLE_MAPS_API_KEY=
PAGO_PRECIO_POR_RUTA=10000
PAGO_PRECIO_POR_ENTREGA=3000
PAGO_PRECIO_POR_BULTO=500
PRECIO_COMBUSTIBLE_LITRO=1200
PRECIO_ESPERA_MINUTO=500

# --- Frontend (build-time en producción; runtime en desarrollo) ---
REACT_APP_API_URL=http://localhost:3000
REACT_APP_GOOGLE_MAPS_API_KEY=TU_API_KEY_DE_GOOGLE_CLOUD
REACT_APP_MQTT_BROKER_URL=ws://localhost:9001
REACT_APP_DEMO_EMAIL=
REACT_APP_DEMO_PASSWORD=
