# ─────────────────────────────────────────────────────────────────────────────
# Frontend WEB (Create React App)
# Solo `REACT_APP_*` se inyecta en el bundle del navegador.
#
# IMPORTANTE: REACT_APP_API_URL puede o no terminar en `/api`.
# El cliente normaliza la URL para evitar duplicar `/api/api/...`.
#   Ejemplos válidos:
#     REACT_APP_API_URL=http://localhost:3000
#     REACT_APP_API_URL=http://192.168.0.4:3000/api
# ─────────────────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:3000
REACT_APP_GOOGLE_MAPS_API_KEY=

# Compatibilidad con clientes Next.js si se reusara este front
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Backend NestJS (NO usar desde el frontend web).
# Se conservan acá solo como referencia: el backend tiene su propio `.env`
# en `backend/.env` (mismas claves) y es quien habla con Supabase / Resend.
# Las claves SUPABASE_*, RESEND_* NUNCA deben quedar expuestas al navegador.
# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# App móvil (Expo) — referencia
# EXPO_PUBLIC_API_URL=http://192.168.0.4:3000
# ─────────────────────────────────────────────────────────────────────────────
