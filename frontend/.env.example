REACT_APP_API_URL=http://localhost:3000
REACT_APP_GOOGLE_MAPS_API_KEY=TU_API_KEY_DE_GOOGLE_CLOUD

# Opcional: prellenar login demo (deben coincidir con DEBUG_EMAIL / DEBUG_PASSWORD del backend)
REACT_APP_DEMO_EMAIL=
REACT_APP_DEMO_PASSWORD=

# Opcional en Windows si aparece: [eslint] EBADF: bad file descriptor
DISABLE_ESLINT_PLUGIN=true
