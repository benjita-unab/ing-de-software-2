# Frontend web (Create React App). Copiar a frontend/.env
# Solo las variables REACT_APP_* se inyectan en el bundle.
#
# REACT_APP_API_URL puede incluir o no el sufijo /api; el cliente en src/lib/apiClient.js normaliza la base.
REACT_APP_API_URL=http://localhost:3000
REACT_APP_GOOGLE_MAPS_API_KEY=

# Compatibilidad con otras plantillas
NEXT_PUBLIC_API_URL=http://localhost:3000

# Si usas claves de Supabase solo en el navegador (anon), añade aquí — nunca service role.
# REACT_APP_SUPABASE_URL=
# REACT_APP_SUPABASE_ANON_KEY=
