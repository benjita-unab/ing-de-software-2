# backend/.env.example
# ─────────────────────────────────────────────────────────────────────────────
# Variables de Entorno para LogiTrack Backend
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como ".env" y completa con tus valores reales

# ── Supabase Configuration ───────────────────────────────────────────────────
# Obtén estos valores desde Supabase Dashboard → Settings → API
# 🔗 https://supabase.com/dashboard/project/[ID]/settings/api

# URL de tu proyecto Supabase
SUPABASE_URL=https://your-project-id.supabase.co

# Service Key (Para operaciones del servidor - ¡MANTÉN EN SECRETO!)
# Usa la clave "service_role" que encontrarás en Settings → API
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Configuración del Servidor ──────────────────────────────────────────────
# Puerto donde correrá el servidor
PORT=3001

# Ambiente (development, staging, production)
NODE_ENV=development

# ── Configuración del Cron Job ──────────────────────────────────────────────
# Expresión cron para la ejecución del job
# "0 0 * * *" = Medianoche (00:00) todos los días
# Formato: minuto hora día mes día-semana
# Ref: https://crontab.guru/
CRON_TIME=0 0 * * *

# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Edita .env con tus valores reales de Supabase
# 3. NUNCA hagas commit de .env al repositorio
# 4. Asegúrate que .env está en tu .gitignore
# ─────────────────────────────────────────────────────────────────────────────
