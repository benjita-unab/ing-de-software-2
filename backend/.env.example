# ============================================================
# Backend LogiTrack - Variables de Entorno
# ============================================================

# Node Environment
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ============================================================
# SUPABASE CONFIGURATION
# ============================================================
# URL de tu proyecto Supabase
SUPABASE_URL=https://jmshzmwhbbufgxgxlpcd.supabase.co

# Service Role Key (SECRETO - Solo en backend)
# Obtén esta clave del dashboard de Supabase > Settings > API
# ⚠️ NUNCA expongas esta clave en el frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Public Key (para validar JWT de Supabase)
# Obtén esta clave del mismo lugar, es la clave pública
SUPABASE_PUBLIC_KEY=eyJhbGc...

# ============================================================
# RESEND CONFIGURATION (Email Service)
# ============================================================
# API Key de Resend (obtén en https://resend.com)
# ⚠️ SECRETO - Solo en backend
RESEND_API_KEY=re_...

# Email remitente verificado en Resend
# Debe estar registrado en tu cuenta de Resend
RESEND_FROM_EMAIL=Sistema LogiTrack <noreply@tudominio.com>

# ============================================================
# CORS & SECURITY
# ============================================================
# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# JWT Secret (opcional, ya usa Supabase)
JWT_SECRET=tu_secret_jwt_aqui

# ============================================================
# LOGGING
# ============================================================
# Niveles: debug, log, warn, error
LOG_LEVEL=debug
