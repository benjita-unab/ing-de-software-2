# ============================================================
# Backend LogiTrack — Variables de entorno (ejemplo)
# Copiar a backend/.env y completar. No subir .env a Git.
# ============================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Supabase (backend usa service role solo en servidor) ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<tu-service-role-key>
# Clave JWT / HS256 — debe coincidir con la firma esperada para validar tokens del cliente si aplica
SUPABASE_PUBLIC_KEY=<clave-publica-anon-o-jwt-segun-tu-setup>

# --- Resend (correo) ---
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Sistema LogiTrack <noreply@tudominio.com>

# --- CORS / front ---
FRONTEND_URL=http://localhost:3001

# --- JWT (NestJS JwtModule / Passport) ---
JWT_SECRET=<cadena-larga-aleatoria>

# --- Login de depuración (AuthService) ---
DEBUG_EMAIL=operador@ejemplo.cl
DEBUG_PASSWORD=<solo-desarrollo>
