{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://logitrack-backend-tmbk.onrender.com",
        "EXPO_PUBLIC_DEBUG_EMAIL": "test@test.com",
        "EXPO_PUBLIC_DEBUG_PASSWORD": "123456"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://logitrack-backend-tmbk.onrender.com",
        "EXPO_PUBLIC_DEBUG_EMAIL": "test@test.com",
        "EXPO_PUBLIC_DEBUG_PASSWORD": "123456"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://logitrack-backend-tmbk.onrender.com",
        "EXPO_PUBLIC_DEBUG_EMAIL": "test@test.com",
        "EXPO_PUBLIC_DEBUG_PASSWORD": "123456"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
